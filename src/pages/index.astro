---
import "../styles/global.css";

const services = [
  {
    title: "Web Development",
    description:
      "Building responsive websites and web applications with modern technologies.",
  },
  {
    title: "Software Solutions",
    description:
      "Creating efficient solutions that solve real-world problems with clean code.",
  },
  {
    title: "Backend & APIs",
    description:
      "Designing reliable APIs and working with databases and server-side logic.",
  },
  {
    title: "Deploy & Maintain",
    description:
      "Deploying applications and keeping them fast, secure, and dependable.",
  },
];

const technologies = ["JS", "TS", "Astro", "CSS", "Node", "Java", "SQL", "Git"];

const projects = [
  {
    title: "Project One",
    description:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor.",
    href: "#",
  },
  {
    title: "Project Two",
    description:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor.",
    href: "#",
  },
  {
    title: "Project Three",
    description:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor.",
    href: "#",
  },
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Alessio Coci - aspiring software developer portfolio."
    />
    <title>AC | Software Developer</title>
  </head>

  <body>
    <header>
      <a class="brand" href="#top">AC</a>
      <nav aria-label="Primary navigation">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="top">
      <section class="intro">
        <h1>I'm Alessio.</h1>
        <p>
          I build modern web applications and enjoy turning ideas into clean,
          functional code. Always learning. Always building.
        </p>
        <a class="button" href="#projects">View my work →</a>
      </section>

      <section id="about">
        <h2>What I do</h2>
        <div class="grid">
          {
            services.map((service) => (
              <article>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section>
        <h2>Tech I work with</h2>
        <ul class="tech">
          {technologies.map((technology) => <li>{technology}</li>)}
        </ul>
      </section>

      <section id="projects">
        <h2>Featured projects</h2>
        <div class="grid">
          {
            projects.map((project) => (
              <article>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <a href={project.href}>View project →</a>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <footer id="contact">
      <p>© {year} Alessio C.</p>
      <a href="mailto:hello@example.com">hello@example.com</a>
    </footer>
  </body>
</html>
