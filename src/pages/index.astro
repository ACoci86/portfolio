---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PixelBar from "../components/PixelBar.astro";

// Each service carries a small inline icon (Feather-style SVG paths).
const services = [
  {
    title: "Full-Stack Web",
    description:
      "Responsive web apps with TypeScript, Angular, Node and Express. Clean, accessible and mobile-first.",
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    title: "Mobile Development",
    description:
      "Cross-platform mobile apps built with Capacitor and modern web tooling.",
    icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
  },
  {
    title: "Backend & APIs",
    description:
      "REST APIs, serverless Cloudflare Functions and Git-based content workflows.",
    icon: '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  },
  {
    title: "QA & Testing",
    description:
      "Manual and Java-based testing, debugging and structured validation workflows.",
    icon: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
  },
];

const technologies = [
  { name: "Java", icon: "/icons/java.svg" },
  { name: "TypeScript", icon: "/icons/typescript.svg" },
  { name: "JavaScript", icon: "/icons/javascript.svg" },
  { name: "Angular", icon: "/icons/angular.svg" },
  { name: "Node", icon: "/icons/nodejs.svg" },
  { name: "Express", icon: "/icons/express.svg" },
  { name: "SQL", icon: "/icons/sql.svg" },
  { name: "Git", icon: "/icons/git.svg" },
];

// Show the three most recent projects on the homepage.
const featured = (await getCollection("projects"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base>
  <section class="intro">
    <h1>Hi, I'm Alessio.</h1>
    <p>
      Junior software developer and First Class Honours Level 8 graduate. I build
      full-stack web and mobile apps, turning ideas into clean, reliable code.
    </p>
    <div class="actions">
      <a class="button" href="/projects">View my work</a>
      <a class="button button-alt" href="mailto:alessiococi1986@gmail.com">
        Contact me
      </a>
    </div>
  </section>

  <section id="about">
    <h2>About</h2>
    <PixelBar />
    <div class="about">
      <p>
        I'm a junior software developer based in Waterford, Ireland, and I came
        to engineering from an unusual direction.
      </p>
      <p>
        For a decade I worked in technical localization and QA, shipping user
        interfaces, software strings, help pages and mobile app content for
        technology clients including Microsoft and Canva. It sat closer to
        engineering than people tend to assume: XML and XLIFF file workflows,
        regex-based validation, QA passes in Xbench, and bug reporting in Jira.
        As a Senior Project Manager at CETRA I ran multilingual digital projects
        across IT, healthcare, finance and government, coordinating clients and
        teams against scope, budget and deadlines, and training new hires on the
        tooling. Before that I supported sellers at Amazon and mentored
        colleagues there.
      </p>
      <p>
        The engineering side kept pulling at me, so I went and got the
        qualification: a Higher Diploma in Science in Software Development (NFQ
        Level 8), finished with First Class Honours. Java and OOP, algorithms and
        data structures, databases, web and mobile development, cloud and
        operating systems, networks, and agile delivery.
      </p>
      <p>
        So I'm new to the job title, not to shipping software. I've spent years
        hitting deadlines for international clients, finding the defects everyone
        else missed, and explaining technical problems to people who don't think
        in code. Now I do it with code.
      </p>
    </div>

    <ul class="facts">
      <li><strong>Based in</strong> Waterford, Ireland</li>
      <li>
        <strong>Education</strong> Higher Diploma in Science in Software
        Development, NFQ Level 8, First Class Honours
      </li>
      <li>
        <strong>Languages</strong> Italian (native), English, Spanish
      </li>
    </ul>
  </section>

  <section>
    <h2>What I do</h2>
    <PixelBar />
    <div class="grid grid-2">
      {
        services.map((service) => (
          <article class="service">
            <svg
              class="service-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={service.icon}
            />
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Tech I work with</h2>
    <PixelBar />
    <ul class="tech">
      {
        technologies.map((technology) => (
          <li>
            <img src={technology.icon} alt={technology.name} width="40" height="40" />
            <span>{technology.name}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section id="projects">
    <h2>Featured projects</h2>
    <PixelBar />
    <div class="grid">
      {
        featured.map((project) => (
          <article>
            {project.data.image && (
              <a href={`/projects/${project.id}`}>
                <img class="card-image" src={project.data.image} alt={project.data.title} />
              </a>
            )}
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <a href={`/projects/${project.id}`}>View project →</a>
          </article>
        ))
      }
    </div>
    <p><a href="/projects">All projects →</a></p>
  </section>
</Base>
