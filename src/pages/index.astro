---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const services = [
  {
    title: "Web Development",
    description:
      "Building responsive websites and web applications with modern technologies.",
  },
  {
    title: "Software Solutions",
    description:
      "Creating efficient solutions that solve real-world problems with clean code.",
  },
  {
    title: "Backend & APIs",
    description:
      "Designing reliable APIs and working with databases and server-side logic.",
  },
  {
    title: "Deploy & Maintain",
    description:
      "Deploying applications and keeping them fast, secure, and dependable.",
  },
];

const technologies = ["JS", "TS", "Astro", "CSS", "Node", "Java", "SQL", "Git"];

// Show the three most recent projects on the homepage.
const featured = (await getCollection("projects"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base>
  <section class="intro">
    <h1>I'm Alessio.</h1>
    <p>
      I build modern web applications and enjoy turning ideas into clean,
      functional code. Always learning. Always building.
    </p>
    <a class="button" href="/projects">View my work</a>
  </section>

  <section id="about">
    <h2>What I do</h2>
    <div class="grid">
      {
        services.map((service) => (
          <article>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Tech I work with</h2>
    <ul class="tech">
      {technologies.map((technology) => <li>{technology}</li>)}
    </ul>
  </section>

  <section id="projects">
    <h2>Featured projects</h2>
    <div class="grid">
      {
        featured.map((project) => (
          <article>
            {project.data.image && (
              <a href={`/projects/${project.id}`}>
                <img class="card-image" src={project.data.image} alt={project.data.title} />
              </a>
            )}
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <a href={`/projects/${project.id}`}>View project →</a>
          </article>
        ))
      }
    </div>
    <p><a href="/projects">All projects →</a></p>
  </section>
</Base>
