---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

// Newest first.
const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base title="Projects | Alessio Coci">
  <section>
    <h1>Projects</h1>
    <p>Things I've built, and what I learned building them.</p>

    <div class="grid">
      {
        projects.map((project) => (
          <article>
            {project.data.image && (
              <a href={`/projects/${project.id}`}>
                <img class="card-image" src={project.data.image} alt={project.data.title} />
              </a>
            )}
            <h3>
              <a href={`/projects/${project.id}`}>{project.data.title}</a>
            </h3>
            <p>{project.data.description}</p>
            <a href={`/projects/${project.id}`}>Read more →</a>
          </article>
        ))
      }
    </div>
  </section>
</Base>
