---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PixelArrow from "../../components/PixelArrow.astro";

// Newest first.
const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base title="Projects | Alessio Coci">
  <section>
    <h1>Projects</h1>
    <p>Things I've built, and what I learned building them.</p>

    <div class="grid grid-3">
      {
        projects.map((project) => (
          <article>
            {project.data.image && (
              <a href={`/projects/${project.id}`}>
                <img class="card-image" src={project.data.image} alt={project.data.title} />
              </a>
            )}
            <h3>
              <a href={`/projects/${project.id}`}>{project.data.title}</a>
            </h3>
            {project.data.tech.length > 0 && (
              <ul class="tech-chips">
                {project.data.tech.map((name) => (
                  <li>{name}</li>
                ))}
              </ul>
            )}
            <p>{project.data.description}</p>
            <a class="pixel-link" href={`/projects/${project.id}`}>
              Read more
              <PixelArrow />
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Base>
