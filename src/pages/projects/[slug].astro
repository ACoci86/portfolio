---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import PixelArrow from "../../components/PixelArrow.astro";

// One page per project file. `id` is the filename without .md (the slug).
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = project.data.date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base
  title={`${project.data.title} | Alessio Coci`}
  description={project.data.description}
  image={project.data.image}
>
  <article class="write-up">
    <a class="pixel-link" href="/projects">
      <PixelArrow dir="left" />
      All projects
    </a>
    <h1>{project.data.title}</h1>
    {
      project.data.image && (
        <img class="write-up-image" src={project.data.image} alt={project.data.title} />
      )
    }
    {
      project.data.tech.length > 0 && (
        <ul class="tech-chips">
          {project.data.tech.map((name) => (
            <li>{name}</li>
          ))}
        </ul>
      )
    }

    <p class="meta">
      <time datetime={project.data.date.toISOString()}>{formattedDate}</time>
      {
        project.data.repo && (
          <>
            {" · "}
            <a class="repo-link" href={project.data.repo} target="_blank" rel="noreferrer">
              <svg
                class="repo-icon"
                viewBox="0 0 16 16"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
                ></path>
              </svg>
              Source
            </a>
          </>
        )
      }
    </p>

    <Content />
  </article>
</Base>
