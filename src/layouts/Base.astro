---
import "../styles/global.css";

const {
  title = "Alessio Coci | Junior Software Developer",
  description =
    "Alessio Coci. First Class Honours Level 8 Software Development graduate. Full-stack web & mobile, backend APIs and QA.",
} = Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <header>
      <a class="brand" href="/">AC</a>
      <nav aria-label="Primary navigation">
        <a href="/#about">About</a>
        <a href="/projects">Projects</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <main id="top">
      <slot />
    </main>

    <footer id="contact">
      <p>© {year} Alessio Coci</p>
      <p>
        <a href="mailto:alessiococi1986@gmail.com">alessiococi1986@gmail.com</a>
        {" · "}
        <a href="https://github.com/ACoci86" target="_blank" rel="noreferrer">
          GitHub
        </a>
      </p>
    </footer>
  </body>
</html>
