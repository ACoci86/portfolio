---
// One or more images that assemble themselves out of blocks and then resolve
// into the real thing, in the same language as the animated Logo. Given more
// than one, they take turns.
//
// The block colours are sampled from each image at build time with sharp, so
// nothing is computed in the browser: the grids ship as plain markup.
import sharp from "sharp";
import path from "node:path";

interface Item {
  src: string; // a path under public/, e.g. "/images/foo.png"
  alt: string;
  href?: string;
}

interface Props {
  images: Item[];
  cols?: number; // blocks across; rows follow from the aspect ratio
}

const { images, cols = 36 } = Astro.props;

// Stack from the floor up, like the logo does.
const ROW_STEP = 0.045;
const DROP = 0.3;
const HOLD = 2.6; // how long the finished image sits before the next one

const slides = await Promise.all(
  images.map(async (item) => {
    const image = sharp(path.join(process.cwd(), "public", item.src));
    const { width = 1, height = 1 } = await image.metadata();
    const rows = Math.max(1, Math.round((cols * height) / width));

    // One pixel per block, straight from a downscale.
    const { data } = await image
      .resize(cols, rows, { fit: "fill" })
      .removeAlpha()
      .raw()
      .toBuffer({ resolveWithObject: true });

    const blocks = [];
    for (let i = 0; i < cols * rows; i++) {
      const o = i * 3;
      blocks.push({
        color: `rgb(${data[o]},${data[o + 1]},${data[o + 2]})`,
        delay: ((rows - 1 - Math.floor(i / cols)) * ROW_STEP).toFixed(3),
      });
    }

    return { ...item, width, height, rows, blocks };
  }),
);

const first = slides[0];
// Every slide runs on the same clock, so the longest one sets the pace.
const settled = (Math.max(...slides.map((s) => s.rows)) - 1) * ROW_STEP + DROP;
const perSlide = settled + 0.45 + HOLD;
---

<div
  class="pixel-reveal"
  style={`--cols:${cols}; --settled:${settled.toFixed(2)}s; --aspect:${first.width}/${first.height}`}
  data-interval={(perSlide * 1000).toFixed(0)}
>
  {
    slides.map((slide, i) => {
      const Tag = slide.href ? "a" : "div";
      return (
        <Tag
          class:list={["pixel-reveal-slide", { "is-active": i === 0 }]}
          href={slide.href}
          style={`--rows:${slide.rows}`}
        >
          <div class="pixel-reveal-grid" aria-hidden="true">
            {slide.blocks.map((b) => (
              <span style={`background:${b.color}; animation-delay:${b.delay}s`} />
            ))}
          </div>
          <img
            src={slide.src}
            alt={slide.alt}
            width={slide.width}
            height={slide.height}
            loading={i === 0 ? "eager" : "lazy"}
          />
        </Tag>
      );
    })
  }
</div>

<script>
  // Assemble once in view, then hand over to the next image on a timer. Anyone
  // who asked for less motion keeps the first image, still.
  const still = matchMedia("(prefers-reduced-motion: reduce)").matches;

  function cycle(root: HTMLElement) {
    const slides = [...root.querySelectorAll<HTMLElement>(".pixel-reveal-slide")];
    if (still || slides.length < 2) return;

    const interval = Number(root.dataset.interval) || 4000;
    let current = 0;

    setInterval(() => {
      slides[current].classList.remove("is-active");
      current = (current + 1) % slides.length;
      slides[current].classList.add("is-active");
    }, interval);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          cycle(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.3 },
  );

  for (const el of document.querySelectorAll(".pixel-reveal")) {
    observer.observe(el);
  }
</script>
