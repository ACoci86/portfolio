---
// A blocky arrow drawn on a 20x10 grid, to match the pixel styling elsewhere.
// The head is a 5-3-1 staircase, so it stays square-edged at any size.
// Decorative: the link text says where it goes, so this is hidden from screen
// readers.
interface Props {
  dir?: "left" | "right";
}

const { dir = "right" } = Astro.props;
---

<svg
  class:list={["pixel-arrow", { "is-left": dir === "left" }]}
  viewBox="0 0 20 10"
  shape-rendering="crispEdges"
  fill="currentColor"
  aria-hidden="true"
>
  <rect x="0" y="4" width="14" height="2"></rect>
  <rect x="14" y="0" width="2" height="10"></rect>
  <rect x="16" y="2" width="2" height="6"></rect>
  <rect x="18" y="4" width="2" height="2"></rect>
</svg>
